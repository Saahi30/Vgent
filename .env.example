# ══════════════════════════════════════════════════════════════
# Vgent — Voice AI Agent SaaS Platform
# Copy this file to .env.local and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=                  # e.g. https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=             # public anon key
SUPABASE_SERVICE_ROLE_KEY=                 # secret service role key (NEVER expose to frontend)
DATABASE_URL=                              # postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Redis (local) ────────────────────────────────────────────
# Default local Redis, no changes needed if running `brew services start redis`
REDIS_URL=redis://localhost:6379

# ── Storage (Cloudflare R2 — optional, for recordings) ──────
# Skip for now, we'll add later for call recordings
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vgent-recordings
R2_PUBLIC_URL=

# ══════════════════════════════════════════════════════════════
# TELEPHONY PROVIDERS
# ══════════════════════════════════════════════════════════════

# ── Twilio ($15 free trial) ──────────────────────────────────
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                       # Your Twilio phone number in E.164 format (+1234567890)
TWILIO_WEBHOOK_BASE_URL=                   # Your public URL (use ngrok for local dev)

# ── Vobiz ────────────────────────────────────────────────────
# Sign up: https://vobiz.ai
VOBIZ_API_KEY=
VOBIZ_WEBHOOK_BASE_URL=

# ── Plivo (trial credits) ───────────────────────────────────
# Sign up: https://www.plivo.com/
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=
PLIVO_WEBHOOK_BASE_URL=

# ══════════════════════════════════════════════════════════════
# LLM PROVIDERS
# ══════════════════════════════════════════════════════════════

# ── Groq (FREE — generous tier) ─────────────────────────────
# Sign up: https://console.groq.com → API Keys
GROQ_API_KEY=

# ── Google Gemini (FREE — 15 RPM, 1M tokens/day) ────────────
# Sign up: https://aistudio.google.com → Get API Key
GOOGLE_API_KEY=

# ── Mistral (FREE tier) ─────────────────────────────────────
# Sign up: https://console.mistral.ai/
MISTRAL_API_KEY=

# ── Together AI ($5 free signup credits) ─────────────────────
# Sign up: https://api.together.xyz/
TOGETHER_API_KEY=

# ── Cohere (FREE trial) ─────────────────────────────────────
# Sign up: https://dashboard.cohere.com/
COHERE_API_KEY=

# ── OpenAI (paid — optional) ────────────────────────────────
# Sign up: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Anthropic (paid — optional) ──────────────────────────────
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ══════════════════════════════════════════════════════════════
# STT (Speech-to-Text) PROVIDERS
# ══════════════════════════════════════════════════════════════

# ── Deepgram ($200 free credits — RECOMMENDED) ──────────────
# Sign up: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=

# ── Google Cloud STT (60 min/month free) ─────────────────────
# Uses GOOGLE_API_KEY above, or set separate credentials:
GOOGLE_CLOUD_CREDENTIALS_JSON=             # Path to service account JSON file (optional)

# ── AssemblyAI ($50 free credits) ────────────────────────────
# Sign up: https://www.assemblyai.com/dashboard
ASSEMBLYAI_API_KEY=

# ── Azure Speech (5 hrs/month free) ─────────────────────────
# Sign up: https://portal.azure.com → Cognitive Services → Speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=                       # e.g. eastus

# ══════════════════════════════════════════════════════════════
# TTS (Text-to-Speech) PROVIDERS
# ══════════════════════════════════════════════════════════════

# ── Edge TTS (FREE — no key needed!) ────────────────────────
# Nothing to configure! Works out of the box.

# ── gTTS (FREE — no key needed!) ────────────────────────────
# Nothing to configure! Works out of the box.

# ── Sarvam AI (FREE tier — Indian languages) ────────────────
# Sign up: https://dashboard.sarvam.ai
# Supports: Hindi, Tamil, Telugu, Kannada, Malayalam, Bengali, etc.
SARVAM_API_KEY=

# ── ElevenLabs (10K chars/month free) ───────────────────────
# Sign up: https://elevenlabs.io
ELEVENLABS_API_KEY=

# ── Google Cloud TTS (4M chars/month free) ───────────────────
# Uses GOOGLE_API_KEY above

# ── Cartesia (limited free) ─────────────────────────────────
# Sign up: https://play.cartesia.ai/
CARTESIA_API_KEY=

# ── Azure TTS (5M chars/month free) ─────────────────────────
# Uses AZURE_SPEECH_KEY and AZURE_SPEECH_REGION above

# ── OpenAI TTS (paid — optional) ────────────────────────────
# Uses OPENAI_API_KEY above

# ── Deepgram Aura TTS ───────────────────────────────────────
# Uses DEEPGRAM_API_KEY above

# ══════════════════════════════════════════════════════════════
# APP CONFIG
# ══════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
API_SECRET_KEY=                            # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
NEXT_PUBLIC_WS_URL=ws://localhost:8000
FERNET_ENCRYPTION_KEY=                     # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# ── Celery ───────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
